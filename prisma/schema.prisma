generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String   // Hash bcrypt
  label     String   // Ej: "Juan & Tania", "Edu & Mai"
  createdAt DateTime @default(now())

  magicToken String? @unique

  profiles   Profile[]
  categories Category[]

  // Configuración de gastos compartidos
  splitMode     SplitMode @default(FONDO_COMUN)
  splitPercentA Float     @default(50) // % del primer perfil (orden alfabético)
  splitPercentB Float     @default(50) // % del segundo perfil

  categoryBudgets CategoryBudget[]
  savingsGoals    SavingsGoal[]
  wallets         Wallet[]
  sharedFundPayments SharedFundPayment[]
}

enum SplitMode {
  FONDO_COMUN
  PORCENTAJE
}

model Profile {
  id        String   @id @default(cuid())
  name      String
  avatar    String?
  accountId String?
  account   Account? @relation(fields: [accountId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  // Telegram integration
  telegramChatId  String?  @unique
  telegramLinkCode String?

  incomes             Income[]
  expenses            Expense[]
  savingsTransactions SavingsTransaction[]
  investments         Investment[]
  budgetConfigs       BudgetConfig[]
  sharedFundPayments  SharedFundPayment[]
}

model Category {
  id        String    @id @default(cuid())
  name      String
  icon      String    @default("📦")
  color     String    @default("#6366f1")
  accountId String?
  account   Account?  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  expenses  Expense[]
  categoryBudgets CategoryBudget[]
}

model Wallet {
  id        String    @id @default(cuid())
  name      String
  currency  String    @default("ARS")
  accountId String
  account   Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  incomes   Income[]
  expenses  Expense[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Income {
  id          String   @id @default(cuid())
  amount      Float
  currency    String   @default("ARS") // ARS, USD, EUR
  date        DateTime
  description String
  profileId   String
  profile     Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  
  walletId    String?
  wallet      Wallet?  @relation(fields: [walletId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Expense {
  id          String   @id @default(cuid())
  amount      Float
  currency    String   @default("ARS")
  date        DateTime
  description String
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])
  profileId   String
  profile     Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  walletId    String?
  wallet      Wallet?  @relation(fields: [walletId], references: [id])

  // Tipo de gasto
  type        ExpenseType @default(PROPIO)

  // Si es COMPARTIDO y se pagó con la billetera personal (ej: Juan paga nafta de sus 50k)
  // El fondo compartido le "debe" ese monto a esa persona
  paidFromPersonalBudget Boolean @default(false)

  // Porcentaje asignado al perfil que pagó/registró (0-100)
  // Usado cuando la cuenta está en modo PORCENTAJE
  splitPercentage Float?

  // Imagen del comprobante
  receiptUrl  String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum ExpenseType {
  PROPIO
  COMPARTIDO
}

model SavingsGoal {
  id              String   @id @default(cuid())
  name            String
  targetAmount    Float?
  isPiggyBank     Boolean  @default(false)
  currency        String   @default("ARS")
  currentAmount   Float    @default(0)
  
  accountId       String
  account         Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  monthsToAchieve Int?
  monthlySplits   Json?    // { profileId: amount }

  transactions    SavingsTransaction[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model SavingsTransaction {
  id            String      @id @default(cuid())
  amount        Float
  type          SavingsType
  description   String?
  savingsGoalId String
  savingsGoal   SavingsGoal @relation(fields: [savingsGoalId], references: [id], onDelete: Cascade)
  profileId     String
  profile       Profile     @relation(fields: [profileId], references: [id], onDelete: Cascade)
  date          DateTime    @default(now())
  createdAt     DateTime    @default(now())
}

enum SavingsType {
  DEPOSITO
  RETIRO
}

model Investment {
  id          String          @id @default(cuid())
  name        String
  type        InvestmentType
  amount      Float
  currency    String          @default("ARS")
  returnRate  Float?          // Tasa de retorno anual %
  startDate   DateTime
  endDate     DateTime?
  notes       String?
  profileId   String
  profile     Profile         @relation(fields: [profileId], references: [id], onDelete: Cascade)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

enum InvestmentType {
  PLAZO_FIJO
  FCI
  ACCIONES
  CRYPTO
  BONOS
  OTRO
}

model ExchangeRate {
  id        String   @id @default(cuid())
  month     Int      // 1-12
  year      Int
  usdToArs  Float
  eurToArs  Float
  eurToUsd  Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([month, year])
}

model BudgetConfig {
  id              String  @id @default(cuid())
  profileId       String
  profile         Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  firstHalfBudget Float   @default(50000) // Presupuesto primera quincena ARS
  secondHalfBudget Float  @default(50000) // Presupuesto segunda quincena ARS
  currency        String  @default("ARS")
  isActive        Boolean @default(true)

  @@unique([profileId])
}

model CategoryBudget {
  id          String   @id @default(cuid())
  month       Int
  year        Int
  amount      Float
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])
  accountId   String
  account     Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([accountId, categoryId, month, year])
}

model SharedFundPayment {
  id          String   @id @default(cuid())
  amount      Float
  date        DateTime @default(now())
  description String?
  
  profileId   String
  profile     Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  
  accountId   String
  account     Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TelegramDraft {
  id           String   @id @default(cuid())
  chatId       String   @unique
  fileIds      String[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
